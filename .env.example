# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/knowledgebase?retryWrites=true&w=majority

# Pinecone vector database API key
# Index name: knowledgebase-entries (dimension: 1536)
PINECONE_API_KEY=your-pinecone-api-key

# Anthropic Claude API key
ANTHROPIC_API_KEY=your-anthropic-api-key

# JWT secret for authentication (generate with: openssl rand -base64 32)
AUTH_SECRET=your-jwt-secret-key-here

# Admin credentials
ADMIN_USERNAME=admin
# Generate password hash with: npx bcryptjs hash "your-password"
ADMIN_PASSWORD_HASH=$2a$10$your-bcrypt-hash-here
